# Etsy API v3 Anahtarı (Keystring)
ETSY_API_KEY=your_etsy_keystring_here

# Etsy API Shared Secret (Şubat 2026'dan itibaren zorunlu)
ETSY_SHARED_SECRET=your_etsy_shared_secret_here

# Etsy Mağaza ID'si (sayısal - API'den alınabilir)
ETSY_SHOP_ID=your_etsy_shop_id_here

# Pinterest Cookie'leri (JSON formatında - sadece GitHub Actions için)
# Lokal geliştirmede cookies.json dosyası kullanılır
PINTEREST_COOKIES=[{"name":"_pinterest_sess","value":"...","domain":".pinterest.com"}]
